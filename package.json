{
  "name": "hisabati",
  "version": "0.1.0",
  "description": "Modular 2D and 3D math utilities for vectors, matrices, transforms, rotations, and math functions.",
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.module.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "test": "node --test",
    "build": "npm run build:lib",
    "build:lib": "rollup -c .config/rollup.config.js",
    "clean": "npm run clean:lib",
    "clean:lib": "rm -r dist"
  },
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "Wima engine contributors",
  "license": "MIT",
  "keywords": [
    "math",
    "vector",
    "matrix",
    "affine",
    "quaternion",
    "transform",
    "2d",
    "3d",
    "game-development",
    "simulation"
  ],
  "homepage": "https://github.com/wimaengine/hisabati#readme",
  "bugs": {
    "url": "https://github.com/wimaengine/hisabati/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wimaengine/hisabati.git"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
