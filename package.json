{
  "name": "hisabati",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "build": "npm run build:types && npm run build:lib",
    "build:lib": "rollup -c .config/rollup.config.js",
    "build:types": "tsc -p .config/type.tsconfig.json",
    "clean": "npm run clean:types && npm run clean:lib",
    "clean:types": "rm -r types",
    "clean:lib": "rm -r dist"
  },
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "Wima engine contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/wimaengine/hisabati.git"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
